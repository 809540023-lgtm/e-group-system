# Render API 配置
# 從 https://dashboard.render.com/account/api-tokens 獲取您的 API 密鑰
RENDER_API_TOKEN=your_render_api_token_here

# Render Owner ID
# 從 https://dashboard.render.com/account 的 URL 中獲取
# URL 格式: https://dashboard.render.com/account?accountId=YOUR_OWNER_ID
RENDER_OWNER_ID=your_owner_id_here
